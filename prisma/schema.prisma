generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Compania {
  id              Int         @id @default(autoincrement())
  nombre          String
  direccion       String
  telefono        String
  fechaCreacion   DateTime    @default(now())

  empleados       Empleado[]
}

model Empleado {
  id           Int      @id @default(autoincrement())
  nombre       String
  apellido     String
  correo       String   @unique
  cargo        String
  salario      Decimal

  companiaId   Int

  compania Compania @relation(fields: [companiaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}