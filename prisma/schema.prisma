generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Compania {
  id            Int        @id @default(autoincrement())
  nombre        String
  direccion     String
  telefono      String
  fechaCreacion DateTime   @default(now())
  empleados     Empleado[]
}

model Usuario {
  id         Int      @id @default(autoincrement())
  correo     String   @unique
  password   String
  role       String   @default("USER")
  ciudad     String?
  companiaId Int?
  createdAt  DateTime @default(now())
}

model Empleado {
  id         Int      @id @default(autoincrement())
  nombre     String
  apellido   String
  correo     String   @unique
  cargo      String
  salario    Decimal
  companiaId Int
  compania   Compania @relation(fields: [companiaId], references: [id], onDelete: Cascade)
}
